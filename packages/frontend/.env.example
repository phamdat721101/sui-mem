NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_CONTEXT_MANAGER_ADDRESS=
NEXT_PUBLIC_MEMORY_STORE_ADDRESS=
NEXT_PUBLIC_AGENT_REGISTRY_ADDRESS=
# Production: https://api.54.251.68.29.nip.io   Local dev: http://localhost:3001
NEXT_PUBLIC_AGENT_BACKEND_URL=http://localhost:3001
NEXT_PUBLIC_CHAIN_ID=421614
NEXT_PUBLIC_WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
NEXT_PUBLIC_WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space

# PRD-W v1.2 — timeline UI on /activity (flip true once API has FEATURE_LOOP_RUN_TIMELINE=true).
NEXT_PUBLIC_FEATURE_LOOP_RUN_TIMELINE=false

# PRD-W v1.3 — seller flow on-chain upgrade.
# Sui network used by explorerTxUrl() to pick the right Suiscan subdomain
# (sui-testnet | sui-mainnet). Defaults to sui-testnet when unset.
NEXT_PUBLIC_SUI_NETWORK=sui-testnet
# Operator wallet that holds the AdminCap. When the connected wallet matches
# this address, /studio/dashboard exposes the on-chain Bedrock whitelist
# controls. Leave blank to hide the admin panel for everyone.
NEXT_PUBLIC_OPENX_ADMIN_ADDRESS=

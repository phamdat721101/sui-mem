{
  "compilerOptions": {
    "target": "ES2020",
    "skipLibCheck": true,
    "moduleResolution": "node16",
    "module": "node16",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}

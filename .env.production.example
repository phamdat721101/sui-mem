# === Database (Supabase) ===
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# === LLM (Bedrock Claude Opus preferred, OpenAI fallback) ===
BEDROCK_API_KEY=your-bedrock-api-key-here
OPENAI_API_KEY=sk-...

# === IPFS ===
PINATA_JWT=
PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs

# === Blockchain ===
PRIVATE_KEY=0x...
PLATFORM_WALLET=0x...

# === Contract Addresses ===
SUBSCRIPTION_CONTROLLER_ADDRESS=0xCC42779858F1cd3F480aD33BcBc5A931D57DfFc3
KNOWLEDGE_REGISTRY_ADDRESS=0x36eca600679E73061318f8C10F6E43aFc06C96E0
BRAIN_KEY_VAULT_ADDRESS=0x07beFe30F0C8Ef8B4c513da22A310eF84E9010c0

# === RPC ===
ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc
BASE_SEPOLIA_RPC=https://sepolia.base.org

# === Frontend (Vercel) ===
NEXT_PUBLIC_SUBSCRIPTION_CONTROLLER_ADDRESS=0xCC42779858F1cd3F480aD33BcBc5A931D57DfFc3
NEXT_PUBLIC_KNOWLEDGE_REGISTRY_ADDRESS=0x36eca600679E73061318f8C10F6E43aFc06C96E0
NEXT_PUBLIC_BRAIN_KEY_VAULT_ADDRESS=0x07beFe30F0C8Ef8B4c513da22A310eF84E9010c0
NEXT_PUBLIC_AGENT_BACKEND_URL=http://localhost:3001
NEXT_PUBLIC_CHAIN_ID=421614
NEXT_PUBLIC_PRIVY_APP_ID=

# === Server ===
PORT=3001
DOMAIN=api.yourdomain.com

# === Feature flags (PRD-18) ===
# Permit-authenticated one-prompt onboarding. Off by default: legacy
# x-wallet-address still works on /v3/marketplace/seller/publish. Flip to
# 'true' to require an x-fhenix-permit on that route only. Migration 025
# must be applied first.
FEATURE_PERMIT_AUTH=false

# PRD-19 — gasless non-crypto seller onboarding. When true, the publish
# path enqueues a chain_ops_queue row and the worker's chain-relayer
# drains it on Arbitrum Sepolia. Migration 026 must be applied first;
# RELAYER_PRIVATE_KEY (or DEPLOYER_PRIVATE_KEY) must be funded.
FEATURE_GASLESS_ONBOARD=false
RELAYER_PRIVATE_KEY=
SLACK_ALERTS_WEBHOOK=
